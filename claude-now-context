#!/usr/bin/env bash
# claude-now-context - manage datetime + response-duration hooks for Claude Code
# https://github.com/pereljon/claude-now-context

set -euo pipefail

VERSION="0.4.0"

# Resolve the hook script path as a sibling of this script
_SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd -P)"
HOOK_SCRIPT="$_SCRIPT_DIR/claude-now-context-hook"
HOOK_CMD_PROMPT="$HOOK_SCRIPT on-prompt"
HOOK_CMD_STOP="$HOOK_SCRIPT on-stop"

HOOK_SIGNATURE='claude-now-context-hook'
LEGACY_HOOK_SIGNATURE='echo "Current datetime:'
DRY_RUN=0

show_help() {
  cat <<EOF
claude-now-context $VERSION

A Claude Code hook that injects the current datetime and previous-response
duration into every prompt as context.

USAGE:
  claude-now-context <command> [scope] [--dry-run]

COMMANDS:
  --install      Install the hooks into settings.json
  --uninstall    Remove the hooks from settings.json
  --status       Report whether the hooks are currently installed
  --version      Print version and exit
  --help         Show this help

SCOPE (optional, defaults to user):
  user           ~/.claude/settings.json
  project        ./.claude/settings.json (in current directory)

FLAGS:
  --dry-run, -n  Print the diff of what would change without writing.
                 Applies to --install and --uninstall.

EXAMPLES:
  claude-now-context --install
  claude-now-context --install project
  claude-now-context --install --dry-run
  claude-now-context --status
  claude-now-context --uninstall

Requires: perl with JSON::PP (both ship with macOS and standard Linux distros).
EOF
}

resolve_settings_path() {
  local scope="${1:-user}"
  case "$scope" in
    user)    echo "${HOME}/.claude/settings.json" ;;
    project) echo ".claude/settings.json" ;;
    *)
      echo "error: unknown scope '$scope' (expected 'user' or 'project')" >&2
      exit 1
      ;;
  esac
}

require_perl() {
  if ! command -v perl >/dev/null 2>&1; then
    echo "error: perl is required (ships with macOS and standard Linux distros)" >&2
    exit 1
  fi
  if ! perl -MJSON::PP -e 1 >/dev/null 2>&1; then
    echo "error: perl JSON::PP module is required (normally ships with Perl 5.14+)" >&2
    exit 1
  fi
}

require_object_root() {
  local settings="$1"
  [[ -f "$settings" ]] || return 0
  perl -MJSON::PP -e '
    use strict; use warnings;
    open my $fh, "<", $ARGV[0] or exit 0;
    local $/;
    my $text = <$fh>;
    close $fh;
    exit 0 unless length $text;
    my $data = eval { decode_json($text) };
    if (!defined $data) {
      print STDERR "refusing to modify $ARGV[0]: invalid JSON\n";
      exit 1;
    }
    if (ref($data) ne "HASH") {
      print STDERR "refusing to modify $ARGV[0]: root JSON value is not an object\n";
      exit 1;
    }
  ' "$settings"
}

# Prints one of: current | outdated | absent
install_state() {
  local settings="$1"
  if [[ ! -f "$settings" ]]; then
    echo absent
    return
  fi
  HOOK_SIGNATURE="$HOOK_SIGNATURE" \
  LEGACY_SIG="$LEGACY_HOOK_SIGNATURE" \
  HOOK_CMD_PROMPT="$HOOK_CMD_PROMPT" \
  HOOK_CMD_STOP="$HOOK_CMD_STOP" \
  perl -MJSON::PP -e '
    use strict; use warnings;
    my $new_sig    = $ENV{HOOK_SIGNATURE};
    my $old_sig    = $ENV{LEGACY_SIG};
    my $prompt_cmd = $ENV{HOOK_CMD_PROMPT};
    my $stop_cmd   = $ENV{HOOK_CMD_STOP};

    open my $fh, "<", $ARGV[0] or do { print "absent"; exit 0 };
    local $/;
    my $text = <$fh>;
    close $fh;
    my $data = eval { decode_json($text) };
    unless ($data && ref($data) eq "HASH") { print "absent"; exit 0 }

    my $matches_sig = sub {
      my $c = shift // "";
      return index($c, $new_sig) >= 0 || index($c, $old_sig) >= 0;
    };

    my $scan = sub {
      my ($hook_type) = @_;
      my @matches;
      return @matches unless ref($data->{hooks}) eq "HASH";
      my $list = $data->{hooks}{$hook_type};
      return @matches unless ref($list) eq "ARRAY";
      for my $entry (@$list) {
        next unless ref($entry) eq "HASH";
        for my $h (@{$entry->{hooks} // []}) {
          next unless ref($h) eq "HASH";
          my $cmd = $h->{command} // "";
          push @matches, $cmd if $matches_sig->($cmd);
        }
      }
      return @matches;
    };

    my @p = $scan->("UserPromptSubmit");
    my @s = $scan->("Stop");

    if (@p == 1 && $p[0] eq $prompt_cmd && @s == 1 && $s[0] eq $stop_cmd) {
      print "current";
    } elsif (@p || @s) {
      print "outdated";
    } else {
      print "absent";
    }
  ' "$settings"
}

write_json_atomic() {
  local settings="$1"
  local action="$2"
  HOOK_SIGNATURE="$HOOK_SIGNATURE" \
  LEGACY_SIG="$LEGACY_HOOK_SIGNATURE" \
  HOOK_CMD_PROMPT="$HOOK_CMD_PROMPT" \
  HOOK_CMD_STOP="$HOOK_CMD_STOP" \
  SETTINGS="$settings" \
  perl -MJSON::PP -e '
    use strict; use warnings;
    my $new_sig    = $ENV{HOOK_SIGNATURE};
    my $old_sig    = $ENV{LEGACY_SIG};
    my $prompt_cmd = $ENV{HOOK_CMD_PROMPT};
    my $stop_cmd   = $ENV{HOOK_CMD_STOP};
    my $file       = $ENV{SETTINGS};
    my $action     = $ARGV[0];

    open my $fh, "<", $file or die "cannot read $file: $!";
    local $/;
    my $text = <$fh>;
    close $fh;
    my $data = decode_json($text);
    die "refusing to modify $file: root JSON value is not an object\n"
      unless ref($data) eq "HASH";

    my $matches_any_sig = sub {
      my $c = shift // "";
      return index($c, $new_sig) >= 0 || index($c, $old_sig) >= 0;
    };

    my $remove_from = sub {
      my ($hook_type) = @_;
      return unless ref($data->{hooks}) eq "HASH";
      my $list = $data->{hooks}{$hook_type};
      return unless ref($list) eq "ARRAY";
      my @kept;
      for my $entry (@$list) {
        next unless ref($entry) eq "HASH";
        my @keep = grep {
          !(ref($_) eq "HASH" && $matches_any_sig->($_->{command}))
        } @{$entry->{hooks} // []};
        push @kept, { %$entry, hooks => \@keep } if @keep;
      }
      if (@kept) {
        $data->{hooks}{$hook_type} = \@kept;
      } else {
        delete $data->{hooks}{$hook_type};
      }
    };

    $remove_from->("UserPromptSubmit");
    $remove_from->("Stop");
    delete $data->{hooks}
      if ref($data->{hooks}) eq "HASH" && !%{$data->{hooks}};

    if ($action eq "install") {
      $data->{hooks} //= {};
      $data->{hooks}{UserPromptSubmit} //= [];
      push @{$data->{hooks}{UserPromptSubmit}},
        { hooks => [{ type => "command", command => $prompt_cmd }] };
      $data->{hooks}{Stop} //= [];
      push @{$data->{hooks}{Stop}},
        { hooks => [{ type => "command", command => $stop_cmd }] };
    } elsif ($action ne "uninstall") {
      die "unknown action: $action";
    }

    my $json = JSON::PP->new->indent(1)->space_after(1)->canonical;
    $json->indent_length(2) if $json->can("indent_length");
    open my $out, ">", "$file.tmp" or die "cannot write $file.tmp: $!";
    print $out $json->encode($data);
    close $out or die "flush failed: $!";
    rename "$file.tmp", $file or die "rename failed: $!";
  ' "$action"
}

cmd_install() {
  require_perl
  local settings
  settings="$(resolve_settings_path "${1:-user}")"
  mkdir -p "$(dirname "$settings")"
  [[ -s "$settings" ]] || echo '{}' > "$settings"

  require_object_root "$settings"

  local state
  state="$(install_state "$settings")"

  if [[ "$state" == "current" ]]; then
    echo "Hooks already installed in $settings - nothing to do."
    return 0
  fi

  if [[ "$DRY_RUN" == "1" ]]; then
    local preview
    preview="$(mktemp)"
    trap 'rm -f "$preview"' RETURN
    cp "$settings" "$preview"
    write_json_atomic "$preview" install
    if [[ "$state" == "outdated" ]]; then
      echo "DRY RUN: would upgrade existing datetime hook to the current format in $settings"
    else
      echo "DRY RUN: would install hooks into $settings"
    fi
    echo "DRY RUN: diff (- current, + after install):"
    diff -u "$settings" "$preview" || true
    return 0
  fi

  cp "$settings" "${settings}.bak.$(date +%s).$$"
  write_json_atomic "$settings" install

  if [[ "$state" == "outdated" ]]; then
    echo "Upgraded existing datetime hook to the current format and added response-duration tracking in $settings"
  else
    echo "Installed datetime and response-duration hooks into $settings"
  fi
  echo "Backup saved alongside as ${settings}.bak.*"
  echo "Takes effect immediately - no session restart needed."
}

cmd_uninstall() {
  require_perl
  local settings
  settings="$(resolve_settings_path "${1:-user}")"

  if [[ ! -f "$settings" ]]; then
    echo "No settings file at $settings - nothing to do."
    return 0
  fi

  require_object_root "$settings"

  local state
  state="$(install_state "$settings")"

  if [[ "$state" == "absent" ]]; then
    echo "Hooks not present in $settings - nothing to do."
    return 0
  fi

  local state_dir="${HOME}/.claude/now-context-state"

  if [[ "$DRY_RUN" == "1" ]]; then
    local preview
    preview="$(mktemp)"
    trap 'rm -f "$preview"' RETURN
    cp "$settings" "$preview"
    write_json_atomic "$preview" uninstall
    echo "DRY RUN: would remove hooks from $settings"
    echo "DRY RUN: diff (- current, + after uninstall):"
    diff -u "$settings" "$preview" || true
    if [[ -d "$state_dir" ]]; then
      echo "DRY RUN: would remove state directory $state_dir"
    fi
    return 0
  fi

  cp "$settings" "${settings}.bak.$(date +%s).$$"
  write_json_atomic "$settings" uninstall

  echo "Removed datetime and response-duration hooks from $settings"
  echo "Backup saved alongside as ${settings}.bak.*"

  if [[ -d "$state_dir" ]]; then
    rm -rf "$state_dir"
    echo "Removed session state directory $state_dir"
  fi
}

cmd_status() {
  require_perl
  local settings
  settings="$(resolve_settings_path "${1:-user}")"

  if [[ ! -f "$settings" ]]; then
    echo "not installed (no settings file at $settings)"
    return 1
  fi

  local state
  state="$(install_state "$settings")"

  case "$state" in
    current)
      echo "prompt hook: installed (path: $settings)"
      echo "stop hook:   installed"
      return 0
      ;;
    outdated)
      echo "hook: outdated (run --install to upgrade)"
      echo "path: $settings"
      return 1
      ;;
    absent)
      echo "not installed in $settings"
      return 1
      ;;
  esac
}

ARGS=()
for arg in "$@"; do
  case "$arg" in
    --dry-run|-n) DRY_RUN=1 ;;
    *) ARGS+=("$arg") ;;
  esac
done
if [[ ${#ARGS[@]} -gt 0 ]]; then
  set -- "${ARGS[@]}"
else
  set --
fi

case "${1:-}" in
  --install|install)     shift; cmd_install "$@" ;;
  --uninstall|uninstall) shift; cmd_uninstall "$@" ;;
  --status|status)       shift; cmd_status "$@" ;;
  --version|-v)          echo "claude-now-context $VERSION" ;;
  --help|-h|"")          show_help ;;
  *)
    echo "error: unknown command '$1'" >&2
    show_help >&2
    exit 1
    ;;
esac
